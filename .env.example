# Copy this file to .env.local, then fill in your own values.
# cp .env.example .env.local

# Required for chat. Keep this value private.
DEEPSEEK_API_KEY="your-deepseek-api-key"

# LLM endpoint settings.
ANTHROPIC_BASE_URL="https://api.deepseek.com/v1"
ANTHROPIC_MODEL="deepseek-chat"
LLM_STREAM_DEBUG="0"

# Local server/frontend ports.
SERVER_PORT="3001"
FRONTEND_PORT="5173"
VITE_API_TARGET="http://localhost:3001"
HOST="0.0.0.0"

# Optional login protection.
# Keep false for quick local startup.
APP_AUTH_ENABLED="false"

# Required only when APP_AUTH_ENABLED=true.
APP_ACCESS_PASSWORD_HASH=""
SESSION_SECRET="replace-with-a-long-random-string"
